run = "bash start.sh"
entrypoint = "server.ts"
modules = ["nodejs-20"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["npm", "start"]
deploymentTarget = "vm"
build = ["npm", "run", "build"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "3000"
INTERVIEW_PORT = "19847"

[agent]
expertMode = true

[userenv]

[userenv.shared]
OBSIDIAN_API_URL = "https://increasingly-dee-lincoln-great.trycloudflare.com"
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
