run = "bash start.sh"
entrypoint = "server.ts"
modules = ["nodejs-20"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["sh", "-c", "npm run build && npm start"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80

[env]
PORT = "3000"
INTERVIEW_PORT = "19847"

[agent]
expertMode = true
