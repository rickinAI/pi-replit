run = "bash start.sh"
entrypoint = "server.ts"
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["npm", "start"]
deploymentTarget = "vm"
build = ["npm", "run", "build"]
publicDir = "dist"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "3000"
INTERVIEW_PORT = "19847"

[agent]
expertMode = true
integrations = ["google-mail:1.0.0"]

[userenv]

[userenv.shared]
OBSIDIAN_API_URL = "https://strip-plot-boring-shared.trycloudflare.com"
PORT = ""
GMAIL_REDIRECT_URI = "https://51b59722-ef80-4e2b-b64d-6dc467d8bb0f-00-17dz1kfqdyzrd.janeway.replit.dev/api/gmail/callback"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 npm run build && PORT=5000 npm start"
waitForPort = 5000
