run = "bash start.sh"
entrypoint = "server.ts"
modules = ["python-3.11", "nodejs-22", "postgresql-16"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["npm", "start"]
deploymentTarget = "vm"
build = ["npm", "run", "build"]
publicDir = "dist"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "3000"
INTERVIEW_PORT = "19847"

[agent]
expertMode = true
integrations = ["google-mail:1.0.0"]

[userenv]

[userenv.shared]
OBSIDIAN_API_URL = "https://obsidian.rickin.live"
PORT = ""

[userenv.development]

[userenv.production]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 npm run build && fuser -k 5000/tcp 2>/dev/null; sleep 1; PORT=5000 npm start"
waitForPort = 5000
