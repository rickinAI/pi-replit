run = "bash start.sh"
entrypoint = "server.ts"
modules = ["python-3.11", "nodejs-22", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["file", "jq"]

[deployment]
run = ["npm", "start"]
deploymentTarget = "vm"
build = ["npm", "run", "build"]
publicDir = "dist"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "3000"
INTERVIEW_PORT = "19847"

[agent]
expertMode = true
integrations = ["google-mail:1.0.0"]

[userenv]

[userenv.shared]
OBSIDIAN_API_URL = "https://obsidian.rickin.live"
PORT = ""
POOJA_PASSWORD = "chicken"

[userenv.development]
GMAIL_REDIRECT_URI = "https://51b59722-ef80-4e2b-b64d-6dc467d8bb0f-00-17dz1kfqdyzrd.janeway.replit.dev/api/gmail/callback"
DEV_TOKEN = "7b6e45ad4e6f6113d41daf0e77910f8d"

[userenv.production]
GMAIL_REDIRECT_URI = "https://rickin.live/api/gmail/callback"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 npm run build && fuser -k 5000/tcp 2>/dev/null; sleep 1; PORT=5000 npm start"
waitForPort = 5000
